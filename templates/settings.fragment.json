{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Read|Grep|Glob|Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 __CLAUDE_HOME__/hooks/secrets-guard.py"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 __CLAUDE_HOME__/hooks/bash-safety-gate.py"
          },
          {
            "type": "command",
            "command": "python3 __CLAUDE_HOME__/hooks/rehydration-clear-guard.py"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 __CLAUDE_HOME__/hooks/write-barrier.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Read|Write|Edit|MultiEdit|NotebookEdit|Grep|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "python3 __CLAUDE_HOME__/hooks/evidence-capture.py"
          }
        ]
      }
    ],
    "PostToolBatch": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 __CLAUDE_HOME__/hooks/posttoolbatch-reconcile.py"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "__CLAUDE_HOME__/hooks/state-snapshot.sh"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 __CLAUDE_HOME__/hooks/postcompact-capture.py"
          },
          {
            "type": "command",
            "command": "__CLAUDE_HOME__/hooks/state-snapshot.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "__CLAUDE_HOME__/hooks/state-snapshot.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 __CLAUDE_HOME__/hooks/rehydration-stop-linter.py"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 __CLAUDE_HOME__/hooks/subagent-lifecycle.py --event start"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 __CLAUDE_HOME__/hooks/subagent-lifecycle.py --event stop"
          }
        ]
      }
    ],
    "TaskCreated": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 __CLAUDE_HOME__/hooks/task-lifecycle.py --event created"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 __CLAUDE_HOME__/hooks/task-lifecycle.py --event completed"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "__CLAUDE_HOME__/hooks/state-snapshot.sh"
          }
        ]
      }
    ]
  }
}
